<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>JuiceBox 🧃</title>
  <link rel="stylesheet" href="/static/style.css" />
  <script>
    // Scoreboard helper. XSS challenges are solved by getting JS to run in this
    // origin and call JuiceBox.solve('<challenge-id>').
    window.JuiceBox = {
      solve: function (id) { return fetch('/api/collect/' + encodeURIComponent(id)); }
    };
  </script>
</head>
<body>
  <header class="topbar">
    <a class="brand" href="/">🧃 JuiceBox</a>
    <form class="searchbar" action="/search" method="get">
      <input type="text" name="q" placeholder="Search juices..." value="" />
      <button type="submit">Search</button>
    </form>
    <nav>
      <a href="/cart">🛒 Cart (<%= cartCount %>)</a>
      <a href="/chat">💬 JuiceBot</a>
      <a href="/scoreboard">🏁 Scoreboard</a>
      <% if (user) { %>
        <a href="/account"><%= user.username %></a>
        <% if (isAdmin) { %><a href="/admin">Admin</a><% } %>
        <a href="/logout">Logout</a>
      <% } else { %>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
      <% } %>
    </nav>
  </header>
  <main class="container">
